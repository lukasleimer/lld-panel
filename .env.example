# LLD Panel - Environment Template
# Kopieren Sie diese Datei zu .env und passen Sie die Werte an

# ============================================================================
# DJANGO CORE
# ============================================================================

# Secret Key - Geheimer Schlüssel für Django
# Generieren: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# In Production NIEMALS den Development-Key nutzen!
SECRET_KEY=your-secret-key-here-change-in-production

# Debug Mode - Sollte NUR in Development True sein!
# WARNUNG: In Production auf False setzen!
DEBUG=True

# Allowed Hosts - Domains/IPs, die diese Django-App servieren darf
# Development: localhost,127.0.0.1
# Production: example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# ENVIRONMENT
# ============================================================================

# Environment Name - development, staging, production
ENVIRONMENT=development

# ============================================================================
# DATABASE (Für zukünftige Nutzung)
# ============================================================================

# DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgresql://user:password@localhost:5432/lld_panel

# ============================================================================
# EMAIL (Für zukünftige Nutzung)
# ============================================================================

# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=localhost
# EMAIL_PORT=1025

# ============================================================================
# CACHE (Für zukünftige Nutzung)
# ============================================================================

# REDIS_URL=redis://127.0.0.1:6379/1
